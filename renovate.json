{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "prHourlyLimit": 5,
    "prConcurrentLimit": 20,
    "labels": [
        "dependencies"
    ],
    "reviewers": [
        "brpaz"
    ],
    "gomod": {
        "fileMatch": [
            "(^|/)go\\.mod$",
            "(^|/)go\\.mod\\.jinja$"
        ]
    },
    "github-actions": {
        "fileMatch": [
            "(^|/)\\.github/workflows/[^/]+\\.ya?ml$",
            "(^|/)\\.github/workflows/[^/]+\\.ya?ml\\.jinja$"
        ]
    }
}