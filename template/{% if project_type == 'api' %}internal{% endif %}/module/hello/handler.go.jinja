package hello

import (
	"encoding/json"
	"net/http"
)

// Handler handles HTTP requests for the hello module.
type Handler struct {
	svc *Service
}

// NewHandler creates a new hello Handler.
func NewHandler(svc *Service) *Handler {
	return &Handler{svc: svc}
}

// RegisterRoutes registers the hello module routes on mux.
func (h *Handler) RegisterRoutes(mux *http.ServeMux) {
	mux.HandleFunc("GET /hello", h.greet)
	mux.HandleFunc("GET /hello/{name}", h.greet)
}

func (h *Handler) greet(w http.ResponseWriter, r *http.Request) {
	name := r.PathValue("name")
	w.Header().Set("Content-Type", "application/json")
	_ = json.NewEncoder(w).Encode(h.svc.Greet(name))
}
