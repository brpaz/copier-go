package hello

import "{{ go_module }}/internal/domain"

// Service handles hello business logic.
type Service struct{}

// NewService creates a new hello Service.
func NewService() *Service {
	return &Service{}
}

// Greet returns a Greeting for the given name.
func (s *Service) Greet(name string) domain.Greeting {
	if name == "" {
		name = "World"
	}
	return domain.Greeting{Message: "Hello, " + name + "!"}
}
