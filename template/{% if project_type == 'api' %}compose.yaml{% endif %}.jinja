version: "3.8"
name: "{{ project_slug }}"
services:
  api:
    build:
      context: .
      target: development
    container_name: api
    ports:
      - "${PORT:-8080}:8080"
      - "2345:2345" # Delve debugger port
    env_file:
      - .env
    depends_on:
      db:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 3s
      retries: 3
    volumes:
      - .:/app
    networks:
      - app

  db:
    image: postgres:18-alpine
    container_name: db
    environment:
      POSTGRES_USER: ${DB_USER:-postgres}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-postgres}
      POSTGRES_DB: ${DB_NAME:-app}
    ports:
      - "${DB_PORT:-5432}:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-postgres}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - app

volumes:
  postgres-data:

networks:
  app:
    driver: bridge
